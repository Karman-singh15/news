generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id          String   @id @default(uuid())
  title       String
  content     String
  url         String   @unique
  source      String
  bias        String
  publishedAt DateTime
  createdAt   DateTime @default(now())
}
